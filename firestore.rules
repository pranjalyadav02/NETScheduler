// Firestore rules for NETScheduler
// - Allows public reads
// - Allows writes only for authenticated users (anonymous OK)
// Deploy with: `firebase deploy --only firestore:rules`

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Shared app document containing progress/tests/revisions
    match /netscheduler/{docId} {
      // Anyone can read the shared state
      allow read: if true;

      // Only authenticated users may write
      // Anonymous auth from the client will satisfy this (request.auth != null)
      allow write: if request.auth != null;
    }

    // Optional: restrict an admin area to users with a custom 'admin' claim
    match /admin/{doc=**} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
